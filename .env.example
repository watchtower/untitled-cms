##
## Untitled CMS — Environment Configuration
## Copy this file to .env and fill in the values below.
## Run `php install.sh` or `composer run setup` after configuring.
##

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="Untitled CMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─── Maintenance Mode ─────────────────────────────────────────────────────────
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database (MongoDB) ───────────────────────────────────────────────────────
# MongoDB is required for production use.
# Install MongoDB locally: https://www.mongodb.com/docs/manual/installation/
# Or use a free cloud cluster:  https://www.mongodb.com/atlas
#
DB_CONNECTION=mongodb
DB_HOST=127.0.0.1
DB_PORT=27017
DB_DATABASE=untitled_cms
# DB_USERNAME=
# DB_PASSWORD=
#
# Atlas URI (use this instead of host/port when connecting to Atlas):
# DB_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/untitled_cms

# ─── Session & Cache ──────────────────────────────────────────────────────────
# Use 'file' locally; 'redis' or 'database' in production.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=database

# ─── Redis (optional) ─────────────────────────────────────────────────────────
# Uncomment and configure if you switch SESSION_DRIVER or CACHE_STORE to 'redis'
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────────────────────
# Use 'log' locally — emails are written to storage/logs/laravel.log
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@untitled-cms.test"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Email Webhook Tracking ──────────────────────────────────────────────────
MAIL_WEBHOOK_PROVIDER=resend        # resend | mailgun | sendgrid

# Resend (default)
RESEND_API_KEY=re_xxxxxxxxxxxx          # resend/resend-laravel v1+ reads this first
RESEND_KEY=re_xxxxxxxxxxxx              # legacy alias, still works as fallback
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxx   # used by app/webhooks/email endpoint

# Mailgun (if using mailgun)
# MAILGUN_WEBHOOK_SIGNING_KEY=key-xxxxxxxx

# SendGrid (if using sendgrid)
# SENDGRID_WEBHOOK_PUBLIC_KEY=MFkwEw...

EMAIL_LOG_TTL_DAYS=90

# ─── Storage (AWS S3 — optional) ─────────────────────────────────────────────
# Required only if FILESYSTEM_DISK=s3
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
# AWS_BUCKET=
# AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Broadcasting ─────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log

# ─── Social Login (optional) ──────────────────────────────────────────────────
# After adding credentials, enable the toggle in Admin → Settings → Auth.
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

# GitHub: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI="${APP_URL}/auth/github/callback"

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
# Set to "true" to expose the AI image generation endpoint from the frontend
# VITE_AUTH_IMAGE_API_URL="${APP_URL}"
# Set to "true" to show social login buttons (requires GOOGLE_*/GITHUB_* keys above)
# VITE_SOCIAL_LOGINS=false

# ─── Vault / Media ────────────────────────────────────────────────────────────
# Enable ClamAV malware scanning on uploaded files (requires clamav daemon running)
CLAMAV_ENABLED=false
# CLAMAV_HOST=127.0.0.1
# CLAMAV_PORT=3310

# ─── Integrations (optional) ──────────────────────────────────────────────────
# CKEditor 5 (cloud builds): https://ckeditor.com/
TINYMCE_API_KEY=""

# ─── Security ─────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── PHP Dev Server (optional) ────────────────────────────────────────────────
# PHP_CLI_SERVER_WORKERS=4
